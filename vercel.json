{
  "version": 2,
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "synthea-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/main.py" },
    { "src": "/assets/(.*)", "dest": "/synthea-frontend/dist/assets/$1" },
    { "src": "/vite.svg", "dest": "/synthea-frontend/dist/vite.svg" },
    { "src": "/(.*)", "dest": "/synthea-frontend/dist/index.html" }
  ]
}

{
  "version": 2,
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "synthea-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/main.py" },
    {
      "src": "/(.*)\\.(js|css|png|svg|jpg|jpeg|gif|ico|woff|woff2|ttf|eot|map|json)$",
      "dest": "/synthea-frontend/$1.$2"
    },
    { "src": "/(.*)", "dest": "/synthea-frontend/index.html" }
  ]
}
